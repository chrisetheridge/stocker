{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    /* Base Options: */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "checkJs": true,

    /* Bundled projects */
    "lib": ["dom", "dom.iterable", "ES2022"],
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "incremental": true,

    /* Path Aliases */
    "baseUrl": ".",
    "paths": {
      "@stocker/config": ["../../packages/config/src/index.ts"],
      "@stocker/core": ["../../packages/core/src/index.ts"],
      "@stocker/db": ["../../packages/db/src/index.ts"],
      "@stocker/llm": ["../../packages/llm/src/index.ts"],
      "@stocker/market-data": ["../../packages/market-data/src/index.ts"],
      "@stocker/source-adapters": [
        "../../packages/source-adapters/src/index.ts"
      ],
      "@stocker/ui": ["../../packages/ui/src/index.ts"],
      "~/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.cjs",
    "**/*.js",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "generated"]
}
